import { MessageBuilder } from '../shared/message-side'

// ---------------------------------------------------------
// 0. POLYFILL & DIAGNOSTICS
// ---------------------------------------------------------
// El bundled IIFE tiene try/catch vacío que traga TODOS los errores.
// Logger debe existir como global para que MessageBuilder() no crashee.
console.log("[app-side] === MODULE LOADING ===");
console.log("[app-side] Logger=" + (typeof Logger) + " messaging=" + (typeof messaging) + " fetch=" + (typeof fetch));

if (typeof Logger === 'undefined') {
  console.log("[app-side] Logger NO existe - instalando polyfill");
  globalThis.Logger = {
    getLogger: function(name) {
      return {
        log: function() { console.log.apply(console, ['[' + name + ']'].concat(Array.prototype.slice.call(arguments))); },
        warn: function() { console.log.apply(console, ['[' + name + '] WARN'].concat(Array.prototype.slice.call(arguments))); },
        error: function() { console.log.apply(console, ['[' + name + '] ERR'].concat(Array.prototype.slice.call(arguments))); },
        debug: function() {},
        info: function() { console.log.apply(console, ['[' + name + ']'].concat(Array.prototype.slice.call(arguments))); }
      };
    }
  };
}

