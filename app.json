{
  "configVersion": "v3",
  "app": {
    "appId": 23796,
    "appName": "LiftCloud",
    "appType": "app",
    "version": {
      "code": 1,
      "name": "1.0.1"
    },
    "icon": "icon.png",
    "vender": "LiftCloud Dev",
    "description": "Exercise logger connected to the cloud"
  },
  "permissions": [
    "data:os.device.info",
    "device:os.local_storage"
  ],
  "runtime": {
    "apiVersion": {
      "compatible": "4.0",
      "target": "4.0",
      "minVersion": "4.0"
    }
  },
  "debug": false,
  "targets": {
    "gt": {
      "module": {
        "page": {
          "pages": [
            "page/gt/home/exercise.page",
            "page/gt/home/details.page",
            "page/gt/home/rest.page",
            "page/gt/home/summary.page"
          ]
        },
        "app-side": {
          "path": "app-side/index"
        }
      },
      "platforms": [
        {
          "st": "r"
        },
        {
          "st": "s"
        }
      ],
      "designWidth": 368
    }
  },
  "i18n": {
    "en-US": {
      "appName": "LiftCloud"
    },
    "zh-CN": {
      "appName": "你好世界"
    }
  },
  "defaultLanguage": "en-US"
}
